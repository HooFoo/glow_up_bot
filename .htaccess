# Отключаем просмотр содержимого папок
Options -Indexes

RewriteEngine On

# 1. Защита чувствительных файлов
<FilesMatch "(\.env|\.git|composer\.(json|lock)|readme\.md|\.sql|Для Гены\.pdf)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# 2. РАЗРЕШАЕМ (белый список)
# Разрешаем админку (всю папку)
RewriteRule ^admin($|/) - [L]

# Разрешаем вебхук
RewriteRule ^bot/webhook\.php$ - [L]
RewriteRule ^bot/prodamus_callback\.php$ - [L]
RewriteRule ^bot/success\.php$ - [L]
RewriteRule ^bot/fail\.php$ - [L]

# Разрешаем иконку
RewriteRule ^favicon\.ico$ - [L]

# 3. ЗАПРЕЩАЕМ всё остальное
# Если запрос не попал под правила выше — выдаем 403 Forbidden
RewriteRule ^.*$ - [F,L]
